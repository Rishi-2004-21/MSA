# MSA Backend — Environment Variables

# ── Optional: OpenAI (for AI qualification, proposals, auto-responses) ──
# Leave blank to run in mock mode (still fully functional)
OPENAI_API_KEY=

# ── Optional: Real Email via Gmail SMTP ──
# Get an App Password: Google Account → Security → 2-Step → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_gmail@gmail.com
FROM_NAME=Ushnik Technologies

# ── Owner notification email ──
OWNER_EMAIL=admin@ushnik.tech

# ── Server ──
PORT=5000
NODE_ENV=development
